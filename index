// ============================================================
// SEARCH & AUTOCOMPLETE
// ============================================================
const searchEl = document.getElementById('search');
const acList = document.getElementById('autocomplete');
const resultEl = document.getElementById('result');

let currentIndex = -1;
let filtered = [];

function getTypeColor(t) { return TYPE_COLORS[t] || '#888'; }

function typeBadge(t) {
  return `<span class="type-badge" style="background:${getTypeColor(t)}">${t}</span>`;
}

function renderResult(poke) {
  const [name, num, types] = poke;
  const matchups = getDefenseMatchups(types);
  const super4x = [], super2x = [], half = [], quarter = [], immune = [];
  Object.entries(matchups).forEach(([t, m]) => {
    if (m === 4) super4x.push(t);
    else if (m === 2) super2x.push(t);
    else if (m === 0.5) half.push(t);
    else if (m === 0.25) quarter.push(t);
    else if (m === 0) immune.push(t);
  });

  const chipHtml = (type, cls, mult) => `
    <div class="matchup-chip ${cls}">
      <span class="type-badge" style="background:${getTypeColor(type)};padding:3px 8px;font-size:11px">${type}</span>
      <span class="chip-mult">${mult}</span>
    </div>`;

  const spriteUrl = `https://img.pokemondb.net/sprites/home/normal/${name.toLowerCase().replace(/[^a-z0-9]/g,'-').replace(/-+/g,'-').replace(/-$/,'')}.png`;

  resultEl.innerHTML = `
    <div class="card">
      <div class="card-header">
        <img class="poke-sprite" src="${spriteUrl}" alt="${name}" onerror="this.src='https://img.pokemondb.net/sprites/sword-shield/icon/${name.toLowerCase().replace(/[^a-z0-9]/g,'-').replace(/-+/g,'-').replace(/-$/,'')}.png'" />
        <div class="poke-info">
          <div class="dex-num">#${String(num).padStart(4,'0')}</div>
          <h2>${name}</h2>
          <div class="type-badges">${types.map(typeBadge).join('')}</div>
        </div>
      </div>
      <div class="card-body">
        ${super4x.length ? `<div class="section-row section-label-weak">
          <div class="section-title">⚠ Weak ×4</div>
          <div class="type-grid">${super4x.map(t=>chipHtml(t,'weak-4x','×4')).join('')}</div>
        </div>` : ''}
        ${super2x.length ? `<div class="section-row section-label-weak">
          <div class="section-title">Weak ×2</div>
          <div class="type-grid">${super2x.map(t=>chipHtml(t,'weak-2x','×2')).join('')}</div>
        </div>` : ''}
        ${half.length ? `<div class="section-row section-label-strong">
          <div class="section-title">Resists ×½</div>
          <div class="type-grid">${half.map(t=>chipHtml(t,'resist-half','×½')).join('')}</div>
        </div>` : ''}
        ${quarter.length ? `<div class="section-row section-label-strong">
          <div class="section-title">Resists ×¼</div>
          <div class="type-grid">${quarter.map(t=>chipHtml(t,'resist-quarter','×¼')).join('')}</div>
        </div>` : ''}
        ${immune.length ? `<div class="section-row section-label-immune">
          <div class="section-title">Immune ×0</div>
          <div class="type-grid">${immune.map(t=>chipHtml(t,'immune','×0')).join('')}</div>
        </div>` : ''}
        ${!super4x.length && !super2x.length && !half.length && !quarter.length && !immune.length
          ? '<p style="color:var(--muted);font-size:14px">No special type matchups.</p>' : ''}
      </div>
    </div>`;
}

function showAutocomplete(query) {
  if (!query) { acList.classList.remove('show'); return; }
  const q = query.toLowerCase();
  filtered = POKEMON.filter(p => p[0].toLowerCase().includes(q)).slice(0, 12);
  if (!filtered.length) { acList.classList.remove('show'); return; }
  acList.innerHTML = filtered.map((p, i) => {
    const [name, num, types] = p;
    return `<div class="ac-item" data-idx="${i}">
      <span class="ac-num">#${String(num).padStart(4,'0')}</span>
      <span>${name}</span>
      <span class="ac-types">${types.map(t=>`<span class="type-badge" style="background:${getTypeColor(t)};padding:2px 7px;font-size:10px">${t}</span>`).join('')}</span>
    </div>`;
  }).join('');
  currentIndex = -1;
  acList.classList.add('show');
}

acList.addEventListener('click', e => {
  const item = e.target.closest('.ac-item');
  if (!item) return;
  const idx = parseInt(item.dataset.idx);
  select(idx);
});

function select(idx) {
  const poke = filtered[idx];
  if (!poke) return;
  searchEl.value = poke[0];
  acList.classList.remove('show');
  renderResult(poke);
}

searchEl.addEventListener('input', e => {
  showAutocomplete(e.target.value.trim());
  if (!e.target.value.trim()) resultEl.innerHTML = '<div class="hint">⬆ Start typing to search all 1025 Pokémon</div>';
});

searchEl.addEventListener('keydown', e => {
  const items = acList.querySelectorAll('.ac-item');
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    currentIndex = Math.min(currentIndex + 1, items.length - 1);
    items.forEach((el, i) => el.classList.toggle('selected', i === currentIndex));
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    currentIndex = Math.max(currentIndex - 1, -1);
    items.forEach((el, i) => el.classList.toggle('selected', i === currentIndex));
  } else if (e.key === 'Enter') {
    if (currentIndex >= 0) { select(currentIndex); return; }
    // exact match
    const q = searchEl.value.trim().toLowerCase();
    const exact = POKEMON.findIndex(p => p[0].toLowerCase() === q);
    if (exact >= 0) renderResult(POKEMON[exact]);
    else if (filtered.length) select(0);
    acList.classList.remove('show');
  } else if (e.key === 'Escape') {
    acList.classList.remove('show');
  }
});

document.addEventListener('click', e => {
  if (!e.target.closest('.search-wrap')) acList.classList.remove('show');
});

searchEl.focus();
</script>

